/* ===== 申请页面 ===== */
.page {
  background: #eceef2;
  min-height: 100vh;
}

/* ---- 自定义导航栏 ---- */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  z-index: 100;
}

.custom-nav-content {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.custom-nav-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #010005;
}

/* ---- Banner 区域 ---- */
.banner-section {
  position: relative;
  width: 750rpx;
  height: 520rpx;
  /* background: #AEC7FF; */
  overflow: hidden;
}

.banner-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 750rpx;
  height: 588rpx;
  /* display: block; */
}

/* ---- 白色主卡片（上叠 Banner） ---- */
.main-card {
  position: relative;
  margin-top: -150rpx;
  margin-left: 22rpx;
  margin-right: 22rpx;
  background: #fff;
  border-radius: 48rpx 48rpx 24rpx 24rpx;
  border: 2rpx solid #fff;
  padding: 0 40rpx 60rpx;
  margin-bottom: 58rpx;
}

/* ---- 必备神器说明栏 ---- */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 170rpx;
  padding: 0 20rpx 0 40rpx;
  border-radius: 48rpx 48rpx 0 0;
  border: 2rpx solid rgba(255, 255, 255, 0.6);
  margin: 0 -40rpx;
  margin-top: 40rpx;
  box-sizing: border-box;
}

.section-header-left {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.section-header-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #010005;
  line-height: 1.4;
}

.section-header-desc {
  font-size: 26rpx;
  color: #888;
  line-height: 1;
}

.section-header-car {
  width: 360rpx;
  height: 200rpx;
  flex-shrink: 0;
  margin-right: -10rpx;
}

/* ---- 两个卡片横向排列 ---- */
.action-cards-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  margin-top: 24rpx;
  margin-bottom: 24rpx;
}

.action-card-small {
  position: relative;
  flex: 1;
  height: 448rpx;
  background: #F5F7FA;
  padding: 24rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  overflow: hidden;
}

.action-card-small-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.recommend-badge-small {
  position: absolute;
  right: 0;
  top: 0;
  width: 125rpx;
  height: 44rpx;
  z-index: 2;
  overflow: hidden;
}

.recommend-badge-small::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 60%;
  height: 100%;
  background: linear-gradient(
    120deg,
    rgba(255, 255, 255, 0) 0%,
    rgba(255, 255, 255, 0.3) 40%,
    rgba(255, 255, 255, 0.6) 50%,
    rgba(255, 255, 255, 0.3) 60%,
    rgba(255, 255, 255, 0) 100%
  );
  z-index: 1;
  animation: shimmer 3s ease-in-out infinite;
  pointer-events: none;
}

@keyframes shimmer {
  0% {
    left: -100%;
  }
  60% {
    left: 150%;
  }
  100% {
    left: 150%;
  }
}

.action-card-small-title {
  position: relative;
  z-index: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #1C2F50 ;
  line-height: 1.3;
  margin-top: 80rpx;
  margin-left: 30rpx;
}

.action-card-small-subtitle {
  position: relative;
  z-index: 1;
  font-size: 40rpx;
  font-weight: 600;
  color: #010005;
  line-height: 1.3;
  margin-top: 12rpx;
  margin-left: 30rpx;
  margin-bottom: 20rpx;
}

/* ---- 绑定认证按钮 ---- */
.bind-btn {
  margin-top: 36rpx;
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.bind-btn-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 88rpx;
  z-index: 0;
}

.bind-btn-text {
  position: relative;
  z-index: 1;
  font-size: 32rpx;
  font-weight: 500;
  color: #FFFFFF;
}

/* ---- 福利官弹窗 ---- */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal-content {
  width: 560rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  text-align: center;
}

.modal-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 30rpx;
}

.qrcode-img {
  width: 400rpx;
  display: block;
  margin: 0 auto 24rpx;
  border-radius: 16rpx;
}

.modal-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 30rpx;
}

.modal-close {
  display: inline-block;
  padding: 16rpx 80rpx;
  background: linear-gradient(135deg, #fdd835, #f5a623);
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.phone-auth-btn {
  width: 100%;
  background: #07c160;
  color: #fff;
  border-radius: 40rpx;
  font-size: 30rpx;
  margin-bottom: 24rpx;
  border: none;
  padding: 20rpx 0;
}

/* 底部弹起手机号授权 */
.phone-sheet-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: -200rpx; /* 延伸到 tabbar 下方确保背景遮住 */
  background: rgba(0, 0, 0, 0.45);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.phone-sheet {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx 40rpx 0;
  padding-bottom: calc(200rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.phone-sheet-bar {
  width: 80rpx;
  height: 8rpx;
  background: #e0e0e0;
  border-radius: 4rpx;
  margin-bottom: 32rpx;
}

.phone-sheet-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 16rpx;
}

.phone-sheet-desc {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 48rpx;
  padding: 0 20rpx;
}

.phone-sheet-btn {
  width: 100%;
  background: #07c160;
  color: #fff;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  padding: 24rpx 0;
  margin-bottom: 24rpx;
}

.phone-sheet-btn::after {
  border: none;
}

.phone-auth-btn::after {
  border: none;
}

/* ---- 弹窗跳过按钮 ---- */
.sheet-skip-btn {
  text-align: center;
  font-size: 28rpx;
  color: #999;
  padding: 20rpx 0 16rpx;
}
